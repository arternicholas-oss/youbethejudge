{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/claude", "destination": "/api/claude" },
    { "source": "/api/case", "destination": "/api/case" },
    { "source": "/api/court", "destination": "/api/court" },
    { "source": "/api/og", "destination": "/api/og" },
    { "source": "/api/auth", "destination": "/api/auth" },
    { "source": "/api/stripe", "destination": "/api/stripe" },
    { "source": "/api/debate", "destination": "/api/debate" },
    { "source": "/api/verdict-card", "destination": "/api/verdict-card" },
    { "source": "/privacy", "destination": "/" },
    { "source": "/terms", "destination": "/" },
    { "source": "/join/:code", "destination": "/" }
  ]
}
